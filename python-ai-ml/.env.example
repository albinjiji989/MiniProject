# ============================================================================
# PYTHON AI/ML SERVICE - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your actual values
# For local development, use localhost URLs
# For Render production, use production URLs

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Port for local development (Render sets PORT automatically in production)
PORT=10000
FLASK_PORT=5001
FLASK_HOST=0.0.0.0

# Environment: development, production, testing
FLASK_ENV=development

# Debug mode: True for local, False for production
DEBUG=True

# ============================================================================
# DATABASE - MONGODB
# ============================================================================
# Get this from MongoDB Atlas: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/DatabaseName
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/PetWelfare?retryWrites=true&w=majority&appName=project

# Example (replace with your actual credentials):
# MONGODB_URI=mongodb+srv://albinjiji2026:albinjiji2026@project.gomrcsv.mongodb.net/PetWelfare?retryWrites=true&w=majority&appName=project

# ============================================================================
# CLOUDINARY (OPTIONAL - FOR IMAGE STORAGE)
# ============================================================================
# Get credentials from: https://cloudinary.com/console
# Leave empty if not using Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=ai_identified_pets
CLOUDINARY_FOLDER=ai-ml/identified-pets

# Example (replace with your actual credentials):
# CLOUDINARY_CLOUD_NAME=dio7ilktz
# CLOUDINARY_API_KEY=142166745553413
# CLOUDINARY_API_SECRET=CO8OAHf5RY6hPRsmsmo0nTKLqac

# ============================================================================
# AI MODEL CONFIGURATION
# ============================================================================
# Model architecture to use
MODEL_TYPE=MobileNetV2

# Pre-trained weights
MODEL_WEIGHTS=imagenet

# Minimum confidence threshold for predictions (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.5

# ============================================================================
# IMAGE PROCESSING
# ============================================================================
# Maximum image size in pixels
MAX_IMAGE_SIZE=1024

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# Save images to disk (false for production, uses memory only)
SAVE_IMAGES_TO_DISK=false

# ============================================================================
# NODE.JS BACKEND INTEGRATION
# ============================================================================
# URL of your Node.js backend
# Local development:
BACKEND_URL=http://localhost:5000

# Production (Vercel):
# BACKEND_URL=https://mini-project-ebon-omega.vercel.app

# Backend API key for authentication (if needed)
BACKEND_API_KEY=

# ============================================================================
# FRONTEND URL (FOR CORS)
# ============================================================================
# URL of your Flutter/Frontend application
# Local development:
FRONTEND_URL=http://localhost:3000

# Production (Vercel):
# FRONTEND_URL=http://mini-project-6ot9.vercel.app

# ============================================================================
# LOGGING
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file name (not used in Render, logs go to stdout)
LOG_FILE=ai_service.log

# ============================================================================
# PERFORMANCE
# ============================================================================
# Enable GPU acceleration (false for most cloud deployments)
ENABLE_GPU=false

# Batch size for predictions
BATCH_SIZE=1

# ============================================================================
# PRODUCTION SETTINGS (FOR RENDER DEPLOYMENT)
# ============================================================================
# When deploying to Render, set these in Render Dashboard:
# 
# FLASK_ENV=production
# DEBUG=False
# MONGODB_URI=mongodb+srv://albinjiji2026:albinjiji2026@project.gomrcsv.mongodb.net/PetWelfare?retryWrites=true&w=majority&appName=project
# BACKEND_URL=https://mini-project-ebon-omega.vercel.app
# FRONTEND_URL=http://mini-project-6ot9.vercel.app
# CLOUDINARY_CLOUD_NAME=dio7ilktz
# CLOUDINARY_API_KEY=142166745553413
# CLOUDINARY_API_SECRET=CO8OAHf5RY6hPRsmsmo0nTKLqac
# 
# Note: PORT is automatically set by Render, don't add it manually

# ============================================================================
# CORS ALLOWED ORIGINS (OPTIONAL)
# ============================================================================
# Comma-separated list of allowed origins for CORS
# Leave empty to allow all origins (*)
# CORS_ORIGINS=https://mini-project-ebon-omega.vercel.app,http://mini-project-6ot9.vercel.app

# ============================================================================
# SECURITY (OPTIONAL)
# ============================================================================
# API key for securing endpoints (if needed)
# API_KEY=your_secret_api_key_here

# JWT secret for token validation (if needed)
# JWT_SECRET=your_jwt_secret_here

# ============================================================================
# RATE LIMITING (OPTIONAL)
# ============================================================================
# Maximum requests per minute per IP
# RATE_LIMIT=60

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit .env file to Git (it's in .gitignore)
# 2. For local development, copy this file to .env and update values
# 3. For Render deployment, add variables in Render Dashboard → Environment
# 4. MongoDB Atlas: Ensure IP whitelist allows 0.0.0.0/0 for Render
# 5. Cloudinary is optional - service works without it
# 6. PORT is auto-set by Render, use 10000 for local development
